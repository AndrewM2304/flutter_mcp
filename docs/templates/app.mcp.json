{
  "inputs": [
    {
      "type": "promptString",
      "id": "flutter-agent-tooling-path",
      "description": "Absolute path to the flutter agent MCP tooling repo on this machine"
    }
  ],
  "servers": {
    "flutter-agent-runtime": {
      "type": "stdio",
      "command": "dart",
      "args": [
        "${input:flutter-agent-tooling-path}/packages/flutter_agent_mcp_server/bin/flutter_agent_mcp_server.dart"
      ],
      "env": {
        "PATH": "${env:HOME}/Development/flutter/bin:/opt/homebrew/bin:/usr/local/bin:${env:PATH}"
      }
    }
  }
}
